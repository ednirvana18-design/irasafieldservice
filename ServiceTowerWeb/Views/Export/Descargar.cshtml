@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>IRASA - Exportar</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body {
            background-color: #f4f7f6;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
            font-family: sans-serif;
        }

        .card {
            border: none;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            width: 100%;
            max-width: 350px;
        }

        .btn-descarga {
            border-radius: 10px;
            padding: 12px;
            font-weight: bold;
            transition: transform 0.2s;
        }

            .btn-descarga:hover {
                transform: scale(1.02);
            }
    </style>
</head>
<body>
    <div class="card p-4 text-center">
        <h4 class="fw-bold mb-1">IRASA Export</h4>
        <p class="text-muted mb-4" style="font-size: 0.9rem;">Orden: <span class="text-dark fw-bold">@ViewBag.Orden</span></p>

        @if (ViewBag.Tipo == "csv")
        {
            <a href="@Url.Action("GenerarCsv", "Export", new { orden = ViewBag.Orden })"
               class="btn btn-success btn-descarga w-100 shadow-sm">
                <i class="fas fa-file-csv me-2"></i>Descargar Excel (CSV)
            </a>
        }
        else
        {
            @* Aquí llamamos al método del PDF que ya tenías *@
            <a href="@Url.Action("ReportePdf", "Mantenimientos", new { orden = ViewBag.Orden })"
               class="btn btn-danger btn-descarga w-100 shadow-sm">
                <i class="fas fa-file-pdf me-2"></i>Descargar Reporte PDF
            </a>
        }

        <hr class="my-4 text-secondary opacity-25">
        <button onclick="window.close()" class="btn btn-link btn-sm text-decoration-none text-secondary">
            Cerrar ventana
        </button>
    </div>
</body>
</html>